# ── MySQL ────────────────────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=noesis_grid
MYSQL_USER=noesis
MYSQL_PASSWORD=changeme
MYSQL_ROOT_PASSWORD=changeme

# ── Grid ─────────────────────────────────────────────────────────────────────
GRID_NAME=genesis
GRID_DOMAIN=genesis.noesis
GRID_PORT=8080
GRID_TICK_RATE_MS=30000

# ── Nous (per-brain) ─────────────────────────────────────────────────────────
NOUS_NAME=sophia
NOUS_CONFIG=./brain/data/nous/sophia.yaml

# ── Dashboard ────────────────────────────────────────────────────────────────
DASHBOARD_PORT=3001
# NEXT_PUBLIC_GRID_ORIGIN is baked into the client bundle at BUILD time.
# Changing this var WITHOUT rebuilding the dashboard image has NO effect.
# Default assumes grid is reachable on the host at localhost:8080.
# D9 CORS allowlist is frozen at localhost:3001 and localhost:3000 — if you
# change DASHBOARD_PORT, you must also widen the grid's CORS config.
# Never put `SECRET_*` values behind a NEXT_PUBLIC_* prefix: the value ends
# up in the client bundle, readable by anyone with browser DevTools.
NEXT_PUBLIC_GRID_ORIGIN=http://localhost:8080

# ── LLM Settings (local) ─────────────────────────────────────────────────────
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=qwen3:4b

# ── LLM Settings (cloud — optional) ──────────────────────────────────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_AI_API_KEY=
# XAI_API_KEY=

# ── Human Channel ────────────────────────────────────────────────────────────
HUMAN_CHANNEL_PORT=9090
